{
  "extends": "@ddd-ts/tools/tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "noErrorTruncation": true,
    "strictPropertyInitialization": false
  },
  "include": [
    "./src/**/*",
    "./src/**/*.json"
  ],
  "exclude": [
    "./src/**/*.spec.ts",
    "./src/**/*.typecheck.spec.ts",
    "./src/test.ts"
  ]
}