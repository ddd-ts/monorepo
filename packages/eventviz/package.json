{
  "name": "@ddd-ts/eventviz",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "repository": {
    "url": "git+https://github.com/ddd-ts/monorepo"
  },
  "type": "module",
  "bin": {
    "eventviz": "./dist/server/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "pnpm run build:client && pnpm run build:server",
    "build:client": "vite build",
    "build:server": "tsdown --config tsdown.config.js --out-dir dist/server src/server/index.ts src/server/cli.ts",
    "dev": "concurrently -k -n srv,web 'pnpm run dev:server' 'pnpm run dev:client'",
    "dev:client": "vite",
    "dev:server": "node --import @swc-node/register/esm-register src/server/cli.ts /Users/arthur-fontaine/Developer/code/gitlab.com/kraaft/monorepo/master",
    "start": "node dist/server/cli.mjs",
    "test": "echo 'no tests yet' && exit 0"
  },
  "dependencies": {
    "birpc": "^2.9.0",
    "chokidar": "^3.6.0",
    "oxc-parser": "^0.128.0",
    "ws": "^8.18.0",
    "open": "^10.1.0"
  },
  "devDependencies": {
    "@ddd-ts/tools": "workspace:*",
    "@swc-node/register": "^1.11.1",
    "@types/node": "^22.14.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.0"
  },
  "exports": {
    ".": "./src/server/index.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/server/index.mjs"
      },
      "./package.json": "./package.json"
    }
  }
}
