{
  "name": "@ddd-ts/freeze",
  "version": "0.0.2",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "repository": {
    "url": "git+https://github.com/ddd-ts/monorepo"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "freeze": "dist/entrypoints/freeze.entrypoint.js"
  },
  "scripts": {
    "build": "tsdown --config node_modules/@ddd-ts/tools/tsdown.config.js src/index.ts src/entrypoints/freeze.entrypoint.ts",
    "test": "jest --config node_modules/@ddd-ts/tools/jest.config.js"
  },
  "peerDependencies": {
    "ts-morph": "^23.0.0",
    "typescript": "^5.5.4"
  },
  "dependencies": {
    "@ddd-ts/core": "workspace:*",
    "@ddd-ts/shape": "workspace:*",
    "@ddd-ts/traits": "workspace:*",
    "@ddd-ts/types": "workspace:*",
    "@prettier/sync": "^0.6.1",
    "prettier": "^3.8.1"
  },
  "devDependencies": {
    "@ddd-ts/tools": "workspace:*",
    "@types/jest": "^29.5.1",
    "@types/node": "^22.14.1"
  },
  "exports": {
    ".": "./src/index.ts",
    "./entrypoints/freeze.entrypoint": "./src/entrypoints/freeze.entrypoint.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "exports": {
      ".": {
        "import": "./dist/index.mjs",
        "require": "./dist/index.js"
      },
      "./entrypoints/freeze.entrypoint": {
        "import": "./dist/entrypoints/freeze.entrypoint.mjs",
        "require": "./dist/entrypoints/freeze.entrypoint.js"
      },
      "./package.json": "./package.json"
    }
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs"
}
